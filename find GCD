[24bcs105@mepcolinux exp4]$cat gcdimp.c
#include"gcdhead.h"
int gcd(int a, int b)
{
   if(a<b)
      return gcd(b,a);
   else if(b==0)
      return a;
   else
      return gcd(b,a%b);
}
