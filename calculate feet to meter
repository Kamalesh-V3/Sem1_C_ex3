#include"ftomhead.h"
float ftoi(float x)
{
   float a;
   a= x*12;
   printf("%2f in inch\n",a);
   return a;
}
float itoc(float y)
{
   float b;
   b=y*2.54;
   printf("%2f in cm\n",b);
   return b;
}
float ctom(float z)
{
   float c;
   c=z/100;
   printf("%2f in meter\n",c);
   return c;
}

