#include"stronghead.h"
int fact(int n)
{
   long int fact=1,j;
   if(n==0||j==1)
      return 1;
   else
      for(j=1;j<=n;++j)
         fact=fact*j;
   return fact;
}
int strong(int a)
{
   int b,c=0,d;
   long int n;
   d=a;
   while(a>0)
   {
      n=a%10;
      b=fact(n);
      c=c+b;
      a=a/10;
   }
   printf("Sum of factorial of given number is %d\n",c);
   if(d==c)
      printf("%d is strong number",c);
   else
      printf("%d is not strong number",c);
}
